# ── API keys (required) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
YOUTUBE_API_KEY=AIza-xxx

# ── Claude models (optional — defaults shown) ────────────────────────────────
# Generation tier vs cheaper classify tier (026).
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5

# ── Database ─────────────────────────────────────────────────────────────────
# Local (non-Docker) dev: point at your own Postgres.
DATABASE_URL=postgresql://your_username@localhost:5432/comprende_ya
DATABASE_ECHO=false

# ── Docker Compose deploy (033) ──────────────────────────────────────────────
# Postgres credentials for the compose `db` service. docker-compose.yml builds
# DATABASE_URL for the api container from these, so you do NOT set DATABASE_URL
# above when running via compose (override it only to use an external database).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=comprende_ya

# PUBLIC, browser-reachable origins — NOT the internal compose name http://api:8000.
# PUBLIC_API_URL is baked into the webapp at BUILD time (VITE_API_BASE_URL); change
# it → rebuild the webapp image. ALLOWED_ORIGINS is the webapp origin(s) the API
# accepts CORS from (comma-separated; never "*", the API sends credentials).
# Unset ALLOWED_ORIGINS falls back to the localhost dev origins.
PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
