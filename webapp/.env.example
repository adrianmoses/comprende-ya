# Base URL of the ComprendeYa API. Read at src/lib/api.ts.
#
# BUILD-TIME: Vite inlines import.meta.env.VITE_API_BASE_URL when you `pnpm build`,
# so this must be the PUBLIC origin reachable from the browser — not an internal
# Docker/compose service name. For dev (`pnpm dev`) the localhost default is fine.
# Under compose, this is supplied as a build arg from PUBLIC_API_URL (see
# webapp/Dockerfile and the repo-root docker-compose.yml), not from this file.
VITE_API_BASE_URL=http://localhost:8000
